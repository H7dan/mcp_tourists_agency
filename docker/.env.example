# Copy to .env and fill in values. Do not commit .env.

# LLM (e.g. Ollama)
# LLM_BASE_URL=http://llm:11434

# Database
# DB_HOST=db
# DB_PORT=5432
# DB_NAME=tourists_agency
# DB_USER=
# DB_PASSWORD=

# Orchestrator (used by bot and other clients)
# ORCHESTRATOR_URL=http://orchestrator:8000

# MCP server (if run as separate container)
# MCP_SERVER_URL=http://mcp_server:8000/mcp

# Telegram Bot
# BOT_TOKEN=
